{
  "name": "mike-electron",
  "productName": "Mike",
  "version": "1.0.0",
  "private": true,
  "description": "Mike desktop shell — auto-boots backend + Presidio + frontend.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:dev": "MIKE_DEV=1 electron .",
    "make-icons": "node scripts/make-icons.js",
    "prepare-dist": "node scripts/prepare-dist.js",
    "package": "node scripts/prepare-dist.js && electron-builder --dir",
    "dist": "node scripts/prepare-dist.js && electron-builder"
  },
  "devDependencies": {
    "electron": "^35.5.0",
    "electron-builder": "^26.8.1",
    "sharp": "^0.33.5"
  },
  "build": {
    "appId": "com.mikelegal.desktop",
    "productName": "Mike",
    "afterPack": "./scripts/afterPack.js",
    "files": [
      "main.js",
      "icon.png",
      "build/**/*",
      "!**/node_modules/.cache",
      "!**/*.{md,log}"
    ],
    "extraResources": [
      {
        "from": "../backend/dist",
        "to": "backend/dist"
      },
      {
        "from": "../backend/migrations",
        "to": "backend/migrations"
      },
      {
        "from": "../backend/package.json",
        "to": "backend/package.json"
      },
      {
        "from": "../backend/node_modules",
        "to": "backend/node_modules",
        "filter": ["**/*", "!**/.bin/**", "!**/.cache/**"]
      },
      {
        "from": "../frontend/.next/standalone",
        "to": "frontend/.next/standalone",
        "filter": ["**/*", "!**/node_modules/.bun/**", "!**/node_modules/.cache/**"]
      },
      {
        "from": "../frontend/.next/static",
        "to": "frontend/.next/static"
      },
      {
        "from": "../frontend/.next/BUILD_ID",
        "to": "frontend/.next/BUILD_ID"
      },
      {
        "from": "../frontend/public",
        "to": "frontend/public"
      },
      {
        "from": "../word-addin/dist",
        "to": "word-addin/dist"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity",
      "target": ["dmg", "zip"]
    },
    "win": {
      "icon": "build/icon.ico"
    },
    "linux": {
      "icon": "build/icons"
    }
  }
}
