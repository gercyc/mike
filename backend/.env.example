PORT=3001
FRONTEND_URL=http://localhost:3000
ADDIN_URL=https://localhost:3002

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
# Opção 1: URL completa (mais simples)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mike

# Opção 2: Variáveis separadas (sobrescrevem DATABASE_URL se presentes)
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=postgres
# DB_NAME=mike

# ---------------------------------------------------------------------------
# JWT secret used to sign auth tokens (min 32 chars)
# ---------------------------------------------------------------------------
JWT_SECRET=your-jwt-secret-minimum-32-characters-long

# ---------------------------------------------------------------------------
# SMTP para envio de e-mails (verificação de conta, recuperação de senha)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=seu-email@gmail.com
SMTP_PASS=sua-senha-de-app
SMTP_FROM=noreply@mike.app

# ---------------------------------------------------------------------------
# Cloudflare R2 / S3-compatible storage
# ---------------------------------------------------------------------------
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=mike

# HMAC key used to sign /download/:token URLs. Required at startup.
# Generate with: openssl rand -hex 32
DOWNLOAD_SIGNING_SECRET=replace-with-a-random-32-byte-hex-string

# ---------------------------------------------------------------------------
# Chaves de API para LLMs
# ---------------------------------------------------------------------------
GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
OPENROUTER_API_KEY=your-openrouter-key

# Chave de criptografia para as API keys dos usuários (mínimo 32 chars)
USER_API_KEYS_ENCRYPTION_SECRET=your-long-random-secret-minimum-32-chars

# Chave secreta geral da aplicação
MIKE_SECRET_KEY=your-mike-secret-key

# Comma-separated list of OpenRouter model IDs to show in addition to free models.
# OPENROUTER_EXTRA_MODELS=anthropic/claude-3.5-sonnet,openai/gpt-4o
OPENROUTER_EXTRA_MODELS=
